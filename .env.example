# 複製成 .env.local 後填入實際值（.env.local 不會進 git）。
# 只有 VITE_ 開頭的變數會暴露給前端，請勿放任何後端 secret / private key。
# 改了 .env.local 後要重啟 `npm run dev` 才會生效。

# 前端呼叫 API 的 base URL（未設用 /api）
VITE_API_BASE_URL=/api

# Vite dev server 把 /api proxy 到的後端位址（前端一律打正式後端 ccAnimateJapan.WebAPI）
VITE_API_PROXY_TARGET=http://localhost:5222

# LINE Login channel id（= 後端 Line:ChannelId）
VITE_LINE_CLIENT_ID=

# 官方帳號加好友連結，例如 https://line.me/R/ti/p/@xxxxxxx（非好友頁用）
VITE_LINE_ADD_FRIEND_URL=

# LINE LIFF ID（= 後端 Line:LiffId），填入後 order-form 頁面才會顯示 LINE Login 按鈕
VITE_LIFF_ID=

